# =====================================================
# Google Sheets Configuration
# =====================================================
# The ID of your Google Spreadsheet.
# Find it in the URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Service Account credentials (JSON key from Google Cloud Console)
# 1. Create a project in Google Cloud Console
# 2. Enable the Google Sheets API
# 3. Create a Service Account and download the JSON key
# 4. Share the spreadsheet with the service account email (Editor access)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the entire private_key value from the JSON.
# Keep the surrounding quotes and the literal \n characters.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# =====================================================
# Tab Names (must match exactly the tabs in your sheet)
# =====================================================
# These have sane defaults; only override if your sheet uses different names.
SHEETS_TAB_NAME=sheets
RESOURCES_TAB_NAME=resources
ARCHIVED_SHEETS_TAB_NAME=archived_sheets
ARCHIVED_RESOURCES_TAB_NAME=archived_resources
